# Required (unless SKIP_PAYMENT=true)
PAY_TO=0x...           # Celo address for x402 payments (USDC)

# Required - Supabase (uses REST API, no direct DB connection)
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SECRET_KEY=...

# Optional - server
PORT=4022

# Optional - dev: bypass x402, test API without facilitator
# SKIP_PAYMENT=true

# Optional - x402 facilitator (Coinbase CDP)
FACILITATOR_URL=https://api.cdp.coinbase.com/platform/v2/x402
CDP_API_KEY_ID=...
CDP_API_KEY_SECRET=...

# Optional - base URL for verification links
BASE_URL=https://hashproof.example.com
