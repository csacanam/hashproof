# ─── Required ──────────────────────────────────────────────────────────────────

# Secret for the admin endpoint POST /admin/entities/:id/verify
# Used to approve entity verification requests and assign authorized wallets
ADMIN_SECRET=change-me-to-a-long-random-string

# Address that receives USDC payments on x402 calls
PAY_TO=0x...

# Thirdweb secret key — used only to format the 402 challenge header.
# Get one at https://thirdweb.com/dashboard
THIRDWEB_SECRET_KEY=...

# EOA wallet that executes transferWithAuthorization on-chain (settlement).
# Must hold native gas tokens on each supported network:
#   Base/Arbitrum → ETH   Celo → CELO   Polygon → MATIC
# A few dollars of ETH covers thousands of settlements on Base.
SETTLER_PRIVATE_KEY=0x...

# Supabase project (uses REST API, no direct DB connection)
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SECRET_KEY=...

# ─── Optional ──────────────────────────────────────────────────────────────────

# Server port (default: 4022)
PORT=4022

# Bypass x402 for local development (no payment required)
# SKIP_PAYMENT=true

# Networks that accept payment. Comma-separated.
# Supported: base, celo, polygon, arbitrum
# Change here → backend reads new network automatically.
X402_NETWORKS=base

# Base URL used in issued credential JSON and QR codes
BASE_URL=https://hashproof.dev

# Pinata IPFS: JWT for uploading credential JSON as decentralized backup.
# Without this, credentials are stored only in the database.
PINATA_JWT=...

# Blockchain registration on Celo (CredentialRegistry contract)
# Required to register credentials on-chain. Set SKIP_CHAIN=true for local dev.
CELO_RPC_URL=https://forno.celo.org
REGISTRY_CONTRACT_ADDRESS=0x7a1B759A602Aba72a70f99Dffd0a386d7504ce9B
CELOSCAN_API_KEY=your_celoscan_api_key
REGISTRY_PRIVATE_KEY=0x...
# SKIP_CHAIN=true

# Custom RPC overrides (optional — defaults to public nodes)
# BASE_RPC_URL=https://mainnet.base.org
# POLYGON_RPC_URL=https://polygon-rpc.com
# ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
