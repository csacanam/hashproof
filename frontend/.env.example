# Backend API base URL
VITE_API_URL=http://localhost:4022

# Thirdweb client ID (for useFetchWithPayment and wallet UI)
# Get one at https://thirdweb.com/dashboard
VITE_THIRDWEB_CLIENT_ID=...

# Networks that accept payment — must match X402_NETWORKS in backend .env
# Supported: base, celo, polygon, arbitrum
# Change here → frontend reads new network automatically.
VITE_X402_NETWORKS=base
